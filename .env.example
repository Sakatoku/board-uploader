# Storage driver: "mock" (in-memory, local/dev only), "vercel-blob" (default),
# or "pcloud".
STORAGE_DRIVER=mock

# --- Vercel Blob (STORAGE_DRIVER=vercel-blob) ---
# On Vercel this is injected automatically once a Blob store is connected.
# For local use, pull it with `vercel env pull` or copy from the dashboard.
BLOB_READ_WRITE_TOKEN=

# --- pCloud (STORAGE_DRIVER=pcloud) ---
PCLOUD_REGION=eu            # "eu" (eapi.pcloud.com) or "us" (api.pcloud.com)
PCLOUD_ACCESS_TOKEN=
# PCLOUD_USERNAME=
# PCLOUD_PASSWORD=
PCLOUD_ROOT_PATH=/board-uploader

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info

# --- Frontend build flags (VITE_*) ---
# Uncomment to show the debug log panel and toggle button in the header.
# VITE_DEBUG_UI=true

# Local dev server port
PORT=3000
