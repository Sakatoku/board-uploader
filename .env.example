# Storage driver: "mock" (in-memory, local/dev only) or "pcloud" (default).
STORAGE_DRIVER=mock

# pCloud credentials (required when STORAGE_DRIVER=pcloud).
# Prefer an OAuth access token; username/password is a fallback.
PCLOUD_REGION=eu            # "eu" (eapi.pcloud.com) or "us" (api.pcloud.com)
PCLOUD_ACCESS_TOKEN=
# PCLOUD_USERNAME=
# PCLOUD_PASSWORD=
PCLOUD_ROOT_PATH=/board-uploader

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info

# Local dev server port
PORT=3000
